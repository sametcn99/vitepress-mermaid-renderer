{
  "name": "vitepress-mermaid-renderer",
  "version": "1.1.22",
  "description": "A VitePress plugin to render Mermaid diagrams with interactive controls",
  "type": "module",
  "main": "./dist/vitepress-mermaid-renderer.umd.cjs",
  "module": "./dist/vitepress-mermaid-renderer.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/vitepress-mermaid-renderer.js",
      "require": "./dist/vitepress-mermaid-renderer.umd.cjs",
      "default": "./dist/vitepress-mermaid-renderer.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "readme": "README.md",
  "author": {
    "name": "sametcn99",
    "url": "https://github.com/sametcn99",
    "email": "sametcn99@gmail.com"
  },
  "sponsor": {
    "url": "https://sametcc.me/support"
  },
  "scripts": {
    "build": "vite build --mode release",
    "pack": "bun pm pack",
    "smoke:prepare": "bun test.ts --prepare-only",
    "smoke:preview": "cd test-project && bun run docs:preview -- --host 127.0.0.1 --port 4173",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "test:e2e": "bun run smoke:prepare && playwright test",
    "lint": "eslint .",
    "format": "prettier --write ."
  },
  "keywords": [
    "plugin",
    "mermaid",
    "diagrams",
    "markdown",
    "vitepress",
    "mermaid-js",
    "documentation",
    "mermaid-diagrams",
    "mermaid-renderer",
    "vitepress-plugin",
    "vitepress-mermaid",
    "vitepress-diagrams",
    "vitepress-plugin-mermaid",
    "vitepress-mermaid-renderer",
    "vitepress-plugin-mermaid-renderer"
  ],
  "license": "GPL-3.0-only",
  "peerDependencies": {
    "vue": "^3.0.0",
    "mermaid": "^11.0.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@eslint/js": "^10.0.1",
    "@vitest/coverage-v8": "^4.1.5",
    "@types/bun": "^1.3.13",
    "@types/node": "^25.6.0",
    "@typescript-eslint/eslint-plugin": "^8.59.0",
    "@typescript-eslint/parser": "^8.59.0",
    "@vitejs/plugin-vue": "^6.0.6",
    "@vue/test-utils": "^2.4.6",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-vue": "^10.9.0",
    "globals": "^17.5.0",
    "happy-dom": "^20.9.0",
    "mermaid": "^11.14.0",
    "prettier": "3.8.3",
    "terser": "^5.46.2",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.0",
    "vite": "^8.0.10",
    "vite-plugin-dts": "^4.5.4",
    "vitepress": "^1.6.4",
    "vitest": "^4.1.5",
    "vue": "^3.5.33",
    "vue-eslint-parser": "^10.4.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/sametcn99/vitepress-mermaid-renderer.git"
  },
  "bugs": {
    "url": "https://github.com/sametcn99/vitepress-mermaid-renderer/issues"
  },
  "homepage": "https://vitepress-mermaid-renderer.vercel.app",
  "engines": {
    "node": ">=16.0.0"
  },
  "packageManager": "bun@1.3.4"
}
